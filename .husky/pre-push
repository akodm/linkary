#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 1. lingui compile 실행
yarn lingui compile

# 2. lingui compile 후 생성/수정된 js 파일들을 확인
JS_FILES=$(git status --porcelain src/locales/*.js 2>/dev/null | grep -E '\.js$' || true)

# js 파일 변경사항이 있으면 스테이징하고 별도 커밋으로 추가
if [ -n "$JS_FILES" ]; then
  # 모든 locale js 파일을 스테이징
  git add src/locales/*.js 2>/dev/null || true
  
  # 스테이징된 js 파일이 있으면 별도 커밋으로 추가 (--no-verify로 무한 루프 방지)
  STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'src/locales/.*\.js$' || true)
  if [ -n "$STAGED_JS" ]; then
    git commit --no-verify -m "chore: update compiled locale files" 2>/dev/null || true
  fi
fi

